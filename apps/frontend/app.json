{
    "expo": {
        "name": "sortund-frontend",
        "slug": "sortund-frontend",
        "version": "1.0.0",
        "orientation": "portrait",
        "scheme": "sortundfrontend",
        "userInterfaceStyle": "automatic",
        "android": {
            "package": "com.sortund.frontend",
            "predictiveBackGestureEnabled": false,
            "adaptiveIcon": {
                "backgroundColor": "#E6F4FE",
                "foregroundImage": "./assets/icon.png",
                "backgroundImage": "./assets/splash.png",
                "monochromeImage": "./assets/icon.png"
            }
        },
        "ios": {
            "bundleIdentifier": "com.sortund.frontend"
        },
        "web": {
            "output": "static"
        },
        "plugins": [
            "expo-router",
            [
                "expo-splash-screen",
                {
                    "backgroundColor": "#208AEF",
                    "image": "./assets/splash.png",
                    "android": {
                        "image": "./assets/icon.png"
                    }
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true,
            "reactCompiler": true
        },
        "extra": {
            "router": {},
            "eas": {
                "projectId": "aaa03654-3fe4-4cfa-a1f8-e327ccf69009"
            }
        }
    }
}

{
    "$schema": "https://turborepo.dev/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": ["dist/**", ".expo/**"]
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "check-types": {
            "dependsOn": ["^check-types"]
        },
        "dev": {
            "cache": false,
            "persistent": true,
            "env": ["ANDROID_HOME"]
        },
        "format": {
            "inputs": ["src/**/*.py", "pyproject.toml"],
            "outputs": []
        },
        "test": {
            "dependsOn": ["^test"],
            "inputs": ["src/**/*.ts", "tsconfig.json", "jest.config.js"],
            "outputs": []
        }
    }
}

{
    "extends": "@repo/typescript-config/base.json",
    "compilerOptions": {
        "jsx": "react-native",
        "lib": ["DOM", "ESNext"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "target": "ESNext",
        "types": ["node", "react", "react-native", "jest"],
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["**/*.ts", "**/*.tsx", ".expo/**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
    "exclude": ["node_modules"],
    "references": []
}

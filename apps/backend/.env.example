# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/sortund

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_secure_random_secret_at_least_32_chars
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=change_me_to_a_different_secure_random_secret_32_chars
JWT_REFRESH_EXPIRES_IN=7d
